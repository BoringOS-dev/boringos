{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boringos.dev/connectors/google/schemas/search_emails.output.json",
  "title": "Gmail search_emails output",
  "type": "object",
  "required": ["messages"],
  "properties": {
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "subject", "snippet", "date"],
        "properties": {
          "id": { "type": "string" },
          "threadId": { "type": "string" },
          "from": { "type": "string" },
          "subject": { "type": "string" },
          "snippet": { "type": "string" },
          "date": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
