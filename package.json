{
  "name": "boringos",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @boringos/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "pnpm --filter @boringos/db generate",
    "db:migrate": "pnpm --filter @boringos/db migrate"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
